{
  "$defs": {
    "ChangelogObservations": {
      "additionalProperties": false,
      "properties": {
        "source_urls": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "title": "Source Urls",
          "type": "array"
        },
        "last_release_date": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Last Release Date"
        },
        "releases_last_12_months": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Releases Last 12 Months"
        },
        "notable_releases": {
          "items": {
            "type": "string"
          },
          "title": "Notable Releases",
          "type": "array"
        },
        "cadence_description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cadence Description"
        }
      },
      "title": "ChangelogObservations",
      "type": "object"
    },
    "ClaimAssessment": {
      "additionalProperties": false,
      "properties": {
        "claim": {
          "minLength": 1,
          "title": "Claim",
          "type": "string"
        },
        "claim_source_urls": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "title": "Claim Source Urls",
          "type": "array"
        },
        "public_evidence": {
          "minLength": 1,
          "title": "Public Evidence",
          "type": "string"
        },
        "evidence_source_urls": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "title": "Evidence Source Urls",
          "type": "array"
        },
        "assessment": {
          "enum": [
            "supported",
            "partially_supported",
            "unsupported",
            "unclear"
          ],
          "title": "Assessment",
          "type": "string"
        },
        "confidence": {
          "enum": [
            "low",
            "medium",
            "high"
          ],
          "title": "Confidence",
          "type": "string"
        },
        "code_review_follow_up_ids": {
          "items": {
            "type": "string"
          },
          "title": "Code Review Follow Up Ids",
          "type": "array"
        }
      },
      "required": [
        "claim",
        "public_evidence",
        "assessment",
        "confidence"
      ],
      "title": "ClaimAssessment",
      "type": "object"
    },
    "CodeReviewFollowUp": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "minLength": 1,
          "title": "Id",
          "type": "string"
        },
        "area": {
          "minLength": 1,
          "title": "Area",
          "type": "string"
        },
        "question": {
          "minLength": 1,
          "title": "Question",
          "type": "string"
        },
        "expected_evidence": {
          "items": {
            "type": "string"
          },
          "title": "Expected Evidence",
          "type": "array"
        },
        "priority": {
          "enum": [
            "low",
            "medium",
            "high"
          ],
          "title": "Priority",
          "type": "string"
        }
      },
      "required": [
        "id",
        "area",
        "question",
        "priority"
      ],
      "title": "CodeReviewFollowUp",
      "type": "object"
    },
    "CompetitorAssessment": {
      "additionalProperties": false,
      "properties": {
        "competitor_name": {
          "minLength": 1,
          "title": "Competitor Name",
          "type": "string"
        },
        "competitor_url": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Competitor Url"
        },
        "similar_capabilities": {
          "items": {
            "type": "string"
          },
          "title": "Similar Capabilities",
          "type": "array"
        },
        "differentiation_notes": {
          "minLength": 1,
          "title": "Differentiation Notes",
          "type": "string"
        },
        "source_urls": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "title": "Source Urls",
          "type": "array"
        }
      },
      "required": [
        "competitor_name",
        "differentiation_notes"
      ],
      "title": "CompetitorAssessment",
      "type": "object"
    },
    "DiligenceTarget": {
      "additionalProperties": false,
      "properties": {
        "company_name": {
          "minLength": 1,
          "title": "Company Name",
          "type": "string"
        },
        "product_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Product Name"
        },
        "product_url": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Product Url"
        },
        "known_urls": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "title": "Known Urls",
          "type": "array"
        },
        "known_competitors": {
          "items": {
            "type": "string"
          },
          "title": "Known Competitors",
          "type": "array"
        },
        "evaluation_prompt": {
          "minLength": 1,
          "title": "Evaluation Prompt",
          "type": "string"
        }
      },
      "required": [
        "company_name",
        "evaluation_prompt"
      ],
      "title": "DiligenceTarget",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "target": {
      "$ref": "#/$defs/DiligenceTarget"
    },
    "claims": {
      "items": {
        "$ref": "#/$defs/ClaimAssessment"
      },
      "title": "Claims",
      "type": "array"
    },
    "release_activity": {
      "anyOf": [
        {
          "$ref": "#/$defs/ChangelogObservations"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "competitors": {
      "items": {
        "$ref": "#/$defs/CompetitorAssessment"
      },
      "title": "Competitors",
      "type": "array"
    },
    "code_review_follow_ups": {
      "items": {
        "$ref": "#/$defs/CodeReviewFollowUp"
      },
      "title": "Code Review Follow Ups",
      "type": "array"
    },
    "evidence_gaps": {
      "items": {
        "type": "string"
      },
      "title": "Evidence Gaps",
      "type": "array"
    },
    "source_urls": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "title": "Source Urls",
      "type": "array"
    }
  },
  "required": [
    "target"
  ],
  "title": "TechnicalDueDiligenceReport",
  "type": "object"
}
